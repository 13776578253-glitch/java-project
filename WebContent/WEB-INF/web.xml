<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID"
         version="4.0">
  <display-name>Health Monitoring and Intelligent Analysis Platform</display-name>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <servlet>
    <servlet-name>frontControllerServlet</servlet-name>
    <servlet-class>buxingchen.FrontControllerServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>

  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/profile</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/record/add</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/record/list</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/sport</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/sleep</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/chronic</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/analysis</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/report</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/prediction</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/ai</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/admin/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/admin/home</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/admin/users</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/admin/statistics</url-pattern>
  </servlet-mapping>
</web-app>
