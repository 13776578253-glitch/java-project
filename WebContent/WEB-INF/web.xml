<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         id="WebApp_ID"
         version="4.0">
  <display-name>Health Monitoring and Intelligent Analysis Platform</display-name>

  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <servlet>
    <servlet-name>frontControllerServlet</servlet-name>
    <servlet-class>buxingchen.FrontControllerServlet</servlet-class>
    <load-on-startup>1</load-on-startup>
  </servlet>
  <servlet>
    <servlet-name>userServlet</servlet-name>
    <servlet-class>chenqingyuan.UserServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>bodyServlet</servlet-name>
    <servlet-class>chenqingyuan.BodyServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>chronicServlet</servlet-name>
    <servlet-class>chenqingyuan.ChronicServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>lifestyleServlet</servlet-name>
    <servlet-class>buxingchen.LifestyleServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>reportServlet</servlet-name>
    <servlet-class>tanghaoli.ReportServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>adminServlet</servlet-name>
    <servlet-class>buxingchen.AdminServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>frontControllerServlet</servlet-name>
    <url-pattern>/page</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>userServlet</servlet-name>
    <url-pattern>/auth</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>bodyServlet</servlet-name>
    <url-pattern>/body</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>chronicServlet</servlet-name>
    <url-pattern>/chronic</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>lifestyleServlet</servlet-name>
    <url-pattern>/lifestyle</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>reportServlet</servlet-name>
    <url-pattern>/report</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>adminServlet</servlet-name>
    <url-pattern>/admin</url-pattern>
  </servlet-mapping>
</web-app>
